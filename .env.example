# Telegram (obrigatório)
TELEGRAM_BOT_TOKEN=coloque_o_token_do_botfather_aqui
TELEGRAM_CHANNEL_ID=@nome_do_seu_canal

# Banco de dados (obrigatório) — controla quais ofertas já foram postadas,
# pra não repetir. Crie grátis em neon.tech ou supabase.com e cole a
# connection string aqui.
DATABASE_URL=postgresql://usuario:senha@host/banco?sslmode=require

# Configurações gerais
MIN_DESCONTO_PERCENTUAL=30
# Quantas ofertas NOVAS postar por execução do script. Combinado com o
# cron do GitHub Actions (roda de hora em hora por padrão), isso controla
# o ritmo de postagem no canal — ex: 3 aqui + cron de hora em hora = até
# 3 posts novos por hora, em vez de uma enxurrada de uma vez só.
MAX_POSTS_POR_EXECUCAO=3

# Mercado Livre — geração de link de afiliado (opcional, mas recomendado)
# Sem isso o bot posta o link direto do produto, sem comissão de afiliado.
#
# ML_AFFILIATE_TAG: seu identificador de afiliado (aparece nos links que
# você já gerou, ex: "filhomibson20220919203726").
#
# ML_COOKIE_HEADER: copie do DevTools (F12 > Network > clique na
# requisição "createLink" > aba Headers > Request Headers > campo Cookie).
# Cole o valor INTEIRO aqui. Expira de tempos em tempos — quando o bot
# parar de gerar link de afiliado, repita esse passo.
# ATENÇÃO: isso é uma credencial de sessão da sua conta. Nunca compartilhe
# esse valor com ninguém nem cole em lugar público.
ML_AFFILIATE_TAG=
ML_COOKIE_HEADER=

# Shopee Affiliate (opcional por enquanto — só usa quando aprovarem o AppID/Secret)
SHOPEE_APP_ID=
SHOPEE_SECRET_KEY=
